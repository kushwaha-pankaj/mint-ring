# Hockley Mint AI Ring Studio — backend environment variables
#
# Copy to apps/api/.env (gitignored), or `export` these in your shell before
# launching ./run_studio.sh.

# Ring detection now runs locally through GroundingDINO
# (IDEA-Research/grounding-dino-tiny). No Roboflow key is required.

# Design page generation (Module 2)
#
# Options for DESIGN_ENGINE:
#   pollinations  free, slow, no key required, text-to-image only (fallback)
#   fal-schnell   fal.ai FLUX Schnell, $0.003/MP, fast text+img2img
#   fal-kontext   fal.ai FLUX Kontext Pro, $0.04/image, identity-preserving edit
#   fal           composite — FLUX Dev hero + Kontext angles/lighting (recommended)
DESIGN_ENGINE=fal
# Fast pack: 4 angles, 4 lighting. Mesh uses Rodin Gen-2 when enabled.
DESIGN_FAST=1
# Hero engine: dev (quality, default) | schnell (fast, can look messy on fine metal)
DESIGN_HERO=dev
# Angle views: turntable/lora (numeric 0/90/180/270 camera control) | kontext (prompt-edit fallback)
DESIGN_ANGLES=turntable
POLLINATIONS_BASE=https://image.pollinations.ai/prompt

# Research 3D mesh (fal Rodin / Meshy / Tripo — runs after angle views when possible)
#   auto            Rodin Gen-2 when four distinct views exist; else Meshy v6
#   rodin           fal-ai/hyper3d/rodin/v2 — hero + up to 4 cardinal views, high detail GLB
#   triposr         fast low-quality preview only (~30–90s)
#   meshy-multi     fal-ai/meshy/v5/multi-image-to-3d — exactly 4 cardinal turntable JPEGs
#   meshy-v6        Meshy v6 single hero (~$0.80, PBR textures)
#   tripo-multiview Tripo v2.5 four views (~$0.40 HD textures)
#   tripo-v25       Tripo v2.5 single image (~$0.40)
#   off             skip mesh stage
DESIGN_MESH=rodin

# Required when any fal-* engine is selected. Create a key at
# https://fal.ai/dashboard/keys and fund a small balance.
FAL_KEY=2b193fbf-1968-4d53-a966-2325eedf7c4a:82238bfe55fb4e5c78dc0f68e3562a78
